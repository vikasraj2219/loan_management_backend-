NODE_ENV=development
PORT=5000
API_PREFIX=/api/v1

MONGO_URI=mongodb://127.0.0.1:27017/loan_management

JWT_SECRET=change_this_to_a_long_random_secret_key
JWT_EXPIRES_IN=1d
JWT_REFRESH_SECRET=change_this_to_a_different_long_random_secret
JWT_REFRESH_EXPIRES_IN=7d

CLIENT_URL=http://localhost:5173

MAX_FILE_UPLOAD_MB=5
UPLOAD_PATH=./uploads

DEFAULT_ADMIN_EMAIL=admin@loanmanager.com
DEFAULT_ADMIN_PASSWORD=Admin@12345
DEFAULT_ADMIN_NAME=Super Admin
